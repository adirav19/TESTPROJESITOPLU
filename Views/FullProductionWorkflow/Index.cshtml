        // ========================================
        //  MÜŞTERİ SİPARİŞİ OLUŞTUR
        // ========================================
        async function createCustomerOrder() {
            console.log("📝 Müşteri siparişi oluşturuluyor...");

            const seri = document.getElementById("siparis_Seri").value.trim();
            const fisNo = document.getElementById("siparis_FisNo").value.trim();
            const cariKod = document.getElementById("siparis_CariKod").value.trim();
            const tarih = document.getElementById("siparis_Tarih").value.trim();
            const tesTarih = document.getElementById("siparis_TesTarih").value.trim();
            const subeKodu = document.getElementById("siparis_SubeKodu").value.trim();
            const ozelKod = document.getElementById("siparis_OzelKod").value.trim();

            console.log("📝 Form verileri:", { seri, fisNo, cariKod, tarih, tesTarih, subeKodu, ozelKod });

            // Zorunlu alan kontrolleri
            if (!seri || !fisNo || !cariKod || !tarih || !tesTarih) {
                console.warn("⚠️ Zorunlu alanlar eksik");
                alert("⚠️ Zorunlu alanları doldurun!");
                return;
            }

            // Tarihleri API formatına çevir (YYYY-MM-DD HH:MM:SS)
            let tarihFormatted = tarih + " 00:00:00";
            let tesTarihFormatted = tesTarih + " 00:00:00";

            console.log("📅 Formatlanmış tarihler:", tarihFormatted, tesTarihFormatted);

            let kalems = [];
            document.querySelectorAll("#siparis_KalemTable tbody tr").forEach((tr, idx) => {
                let stokKodu = tr.querySelector(".siparis_stokKodu").value.trim();
                let depoKodu = tr.querySelector(".siparis_depoKodu").value.trim();
                let miktar = tr.querySelector(".siparis_miktar").value.trim();
                let bf = tr.querySelector(".siparis_bf").value.trim();

                console.log(`📦 Kalem ${idx + 1}:`, { stokKodu, depoKodu, miktar, bf });

                if (!stokKodu) {
                    console.warn(`⚠️ Kalem ${idx + 1} stok kodu boş, atlanıyor`);
                    return;
                }

                kalems.push({
                    StokKodu: stokKodu,
                    DEPO_KODU: depoKodu ? parseInt(depoKodu) : 10,
                    STra_GCMIK: miktar ? parseFloat(miktar.replace(",", ".")) : 0,
                    STra_BF: bf ? parseFloat(bf.replace(",", ".")) : 0
                });
            });

            console.log("📦 Toplam kalem sayısı:", kalems.length);

            if (kalems.length === 0) {
                console.warn("⚠️ Hiç kalem girilmedi");
                alert("En az bir stok kalemi girmeniz gerekiyor.");
                return;
            }

            let payload = {
                FaturaTip: 7,
                Seri: seri,
                SonNumaraYazilsin: false,
                FatUst: {
                    FATIRS_NO: fisNo,
                    CariKod: cariKod,
                    Tarih: tarihFormatted,
                    Tes_Tarih: tesTarihFormatted,
                    Sube_Kodu: subeKodu ? parseInt(subeKodu) : 0,
                    OZEL_KOD: ozelKod || "1",
                    KDV_DAHILMI: true,
                    Tip: 7,
                    TIPI: 7,
                    AMBHARTUR: 0
                },
                Kalems: kalems
            };

            console.log("📤 Gönderilen payload:", JSON.stringify(payload, null, 2));

            try {
                const response = await fetch('/MusteriSiparisi/Create', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                console.log("📤 Response status:", response.status);

                const result = await response.json();
                console.log("📥 API Response:", result);

                if (result.IsSuccessful === true) {
                    console.log("✅ Sipariş başarıyla oluşturuldu:", fisNo);
                    alert("✅ Sipariş başarıyla oluşturuldu! Fiş No: " + fisNo);

                    // Formu temizle
                    document.getElementById("siparis_FisNo").value = '';
                    document.getElementById("siparis_CariKod").value = '';

                    // Listeyi yenile
                    await loadCustomerOrders();

                } else {
                    console.error("❌ Sipariş oluşturulamadı:", result.ErrorDesc);
                    alert("❌ Kayıt başarısız: " + (result.ErrorDesc || "Bilinmeyen hata"));
                }

            } catch (err) {
                console.error("❌ createCustomerOrder ERROR:", err);
                alert("Hata oluştu: " + err);
            }
        }

