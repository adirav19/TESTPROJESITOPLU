            } catch (err) {
                console.error("❌ toggleFisDetail ERROR:", err);
                container.innerHTML = '<div style="color:var(--danger-red);">Hata oluştu</div>';
            }
        }

        // ===============================================
        //             INLINE EDIT aktif et
        // ===============================================
        function activateInlineEdit(parent, fisNo) {
            console.log("✏️ Inline edit aktif ediliyor");

            parent.querySelectorAll(".editable").forEach(cell => {
                cell.addEventListener("click", function () {
                    if (this.querySelector("input"))
                        return;

                    let oldValue = this.innerText;
                    let input = document.createElement("input");
                    input.classList.add("form-control-custom");
                    input.style.fontSize = "12px";
                    input.style.padding = "4px";
                    input.value = oldValue;

                    this.innerHTML = "";
                    this.appendChild(input);
                    input.focus();

                    input.addEventListener("blur", () => saveCell(this, oldValue, fisNo));
                    input.addEventListener("keydown", e => {
                        if (e.key === "Enter")
                            saveCell(this, oldValue, fisNo);
                    });
                });
            });
        }

        // ===============================================
        //           SAVE FULL JSON → /Save
        // ===============================================
        function saveCell(cell, oldValue, fisNo) {
            console.log("💾 Hücre kaydediliyor...");

            let input = cell.querySelector("input");
            let newValue = input.value;

            if (oldValue == newValue) {
                console.log("⏭️ Değer değişmedi, kaydetme iptal");
                cell.innerHTML = oldValue;
                return;
            }

            let tr = cell.closest("tr");
            let incKey = parseInt(tr.dataset.inckey);

            let detailRow = document.getElementById(`detail-${fisNo}`);
            let holder = detailRow.querySelector(".jsonHolder");
            let fullJson = JSON.parse(holder.textContent);

            console.log("📝 Güncelleniyor - IncKey:", incKey, "Alan:", cell.dataset.field, "Yeni Değer:", newValue);

            // ✔ Kalemi bul ve güncelle
            fullJson.Kalem.forEach(k => {
                if (k.IncKeyNo === incKey) {
                    k[cell.dataset.field] = parseFloat(newValue);
                }
            });

            console.log("📤 Save API'ye gönderiliyor...");

            // ✔ SAVE API
            fetch('/FinishedGoodsReceiptWChanges/Save', {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(fullJson)
            })
                .then(r => r.json())
                .then(res => {
                    console.log("📥 Save Response:", res);

                    if (res.IsSuccessful === true) {
                        holder.textContent = JSON.stringify(fullJson);
                        cell.innerHTML = newValue;
                        cell.style.backgroundColor = "#c4ffda";
                        console.log("✅ Kaydedildi!");
                        setTimeout(() => cell.style.backgroundColor = "", 600);
                    }
                    else {
                        console.error("❌ Kaydetme başarısız:", res.ErrorDesc);
                        alert("Kaydedilemedi: " + res.ErrorDesc);
                        cell.innerHTML = oldValue;
                    }
                })
                .catch(err => {
                    console.error("❌ Save ERROR:", err);
                    alert("Kayıt sırasında hata oluştu!");
                    cell.innerHTML = oldValue;
                });
        }

        // ========================================
        //  İŞ EMRİ OLUŞTUR
        // ========================================
        async function createProductionOrder() {
            console.log("🔧 İş emri oluşturuluyor...");

            const isEmriNo = document.getElementById("isemri_IsEmriNo").value.trim();
            const tarih = document.getElementById("isemri_Tarih").value.trim();
            const stokKodu = document.getElementById("isemri_StokKodu").value.trim();
            const miktar = document.getElementById("isemri_Miktar").value.trim();
            const teslimTarihi = document.getElementById("isemri_TeslimTarihi").value.trim();
            const depoKodu = document.getElementById("isemri_DepoKodu").value.trim();
            const cikisDepoKodu = document.getElementById("isemri_CikisDepoKodu").value.trim();
            const siparisNo = document.getElementById("isemri_SiparisNo").value.trim();

            console.log("🔧 Form verileri:", { isEmriNo, tarih, stokKodu, miktar, teslimTarihi, depoKodu, cikisDepoKodu, siparisNo });

            if (!isEmriNo || !tarih || !stokKodu || !miktar || !teslimTarihi || !depoKodu || !cikisDepoKodu) {
                console.warn("⚠️ Zorunlu alanlar eksik");
                alert("⚠️ Zorunlu alanları doldurun!");
                return;
            }

            const payload = {
                IsEmriNo: isEmriNo,
                Tarih: tarih + " 00:00:00",
                StokKodu: stokKodu,
                Miktar: parseFloat(miktar),
                TeslimTarihi: teslimTarihi + " 00:00:00",
                DepoKodu: parseInt(depoKodu),
                CikisDepoKodu: parseInt(cikisDepoKodu),
                SiparisNo: siparisNo || null,
                Aciklama: ""
            };

            console.log("📤 Gönderilen payload:", JSON.stringify(payload, null, 2));

            try {
                const response = await fetch('/FullProductionWorkflow/CreateProductionOrder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                console.log("📤 Response status:", response.status);

                const result = await response.json();
                console.log("📥 API Response:", result);

                if (result.IsSuccessful === true) {
                    console.log("✅ İş emri başarıyla oluşturuldu");
                    alert("✅ İş emri başarıyla oluşturuldu!");
                    await loadProductionOrders();

                    // Formu temizle
                    document.getElementById("isemri_IsEmriNo").value = '';
                    document.getElementById("isemri_StokKodu").value = '';
                    document.getElementById("isemri_Miktar").value = '';
                    document.getElementById("isemri_SiparisNo").value = '';
                } else {
                    console.error("❌ İş emri oluşturulamadı:", result.ErrorDesc);
                    alert("❌ İş emri oluşturulamadı: " + (result.ErrorDesc || "Bilinmeyen hata"));
                }

            } catch (err) {
                console.error("❌ createProductionOrder ERROR:", err);
                alert("İş emri oluşturulurken hata oluştu: " + err.message);
            }
        }

    </script>
}
