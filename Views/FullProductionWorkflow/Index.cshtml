@{
    ViewData["Title"] = "Tam Üretim Akışı";
    ViewData["FullWidth"] = true;
}

<style>
    :root {
        --border-color: #e1e4e8;
        --bg-panel: #ffffff;
        --bg-hover: #f6f8fa;
        --text-primary: #24292e;
        --text-secondary: #586069;
        --accent-blue: #0366d6;
        --success-green: #28a745;
        --danger-red: #d73a49;
    }

    body {
        background: #f6f8fa;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    }

    .workflow-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        padding: 12px;
        max-width: 100%;
        margin: 0;
    }

    /* Tablet: 2x2 Grid */
    @@media (max-width: 1200px) {
        .workflow-container {
            grid-template-columns: 1fr 1fr;
        }
    }

    /* Mobile: Tek Kolon */
    @@media (max-width: 768px) {
        .workflow-container {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .workflow-panel {
            max-height: none;
            min-height: 400px;
        }

        .panel-body {
            max-height: 400px;
        }
    }

    .workflow-panel {
        background: var(--bg-panel);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 100px);
    }

    .panel-header {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-color);
        background: var(--bg-hover);
        font-weight: 600;
        font-size: 14px;
        color: var(--text-primary);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .panel-body {
        padding: 12px;
        overflow-y: auto;
        flex: 1;
    }

        .panel-body::-webkit-scrollbar {
            width: 8px;
        }

        .panel-body::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        .panel-body::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 4px;
        }

    .form-group {
        margin-bottom: 10px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .form-control-custom {
        width: 100%;
        padding: 8px 12px;
        font-size: 14px;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        background: var(--bg-panel);
        transition: border-color 0.15s;
    }

        .form-control-custom:focus {
            outline: none;
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(3, 102, 214, 0.1);
        }

    .btn-custom {
        padding: 8px 16px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-success-custom {
        background: var(--success-green);
        color: white;
    }

        .btn-success-custom:hover {
            background: #22863a;
        }

    .btn-primary-custom {
        background: var(--accent-blue);
        color: white;
    }

        .btn-primary-custom:hover {
            background: #0256c7;
        }

    .btn-danger-custom {
        background: var(--danger-red);
        color: white;
    }

        .btn-danger-custom:hover {
            background: #cb2431;
        }

    .table-custom {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .table-custom thead {
            background: var(--bg-hover);
            border-bottom: 2px solid var(--border-color);
        }

        .table-custom th {
            padding: 10px 12px;
            text-align: left;
            font-weight: 600;
            color: var(--text-primary);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .table-custom td {
            padding: 10px 12px;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-primary);
        }

        .table-custom tbody tr {
            cursor: pointer;
            transition: background 0.1s;
        }

            .table-custom tbody tr:hover {
                background: var(--bg-hover);
            }

            .table-custom tbody tr.selected {
                background: #e3f2fd;
            }

    .create-form {
        background: var(--bg-hover);
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 12px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin-bottom: 8px;
    }

    @@media (max-width: 480px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .table-custom {
            font-size: 11px;
        }

            .table-custom th, .table-custom td {
                padding: 6px 8px;
            }
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 48px;
        margin-bottom: 12px;
        opacity: 0.3;
    }

    .loading {
        text-align: center;
        padding: 20px;
        color: var(--text-secondary);
    }

    .badge-custom {
        display: inline-block;
        padding: 2px 8px;
        font-size: 11px;
        font-weight: 600;
        border-radius: 12px;
        background: var(--bg-hover);
        color: var(--text-secondary);
    }

    .section-divider {
        border-top: 1px solid var(--border-color);
        margin: 12px 0;
        padding-top: 12px;
    }

    .section-title {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .step-indicator {
        display: inline-block;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--accent-blue);
        color: white;
        text-align: center;
        line-height: 24px;
        font-size: 12px;
        font-weight: 600;
        margin-right: 8px;
    }
</style>

<div class="workflow-container">

    <!-- ========================================
         1️⃣  MÜŞTERİ SİPARİŞİ
    ========================================= -->
    <div class="workflow-panel">
        <div class="panel-header">
            <span>📋 Müşteri Siparişi</span>
            <span class="step-indicator">1</span>
        </div>
        <div class="panel-body">

            <div class="create-form" style="max-height:400px; overflow-y:auto;">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Seri *</label>
                        <input id="siparis_Seri" class="form-control-custom" placeholder="S" value="S" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fiş No *</label>
                        <input id="siparis_FisNo" class="form-control-custom" placeholder="000000000000123" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Cari Kodu *</label>
                    <input id="siparis_CariKod" class="form-control-custom" placeholder="Cari kodu" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Tarih *</label>
                        <input id="siparis_Tarih" type="date" class="form-control-custom" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Teslim Tarihi *</label>
                        <input id="siparis_TesTarih" type="date" class="form-control-custom" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Şube Kodu</label>
                        <input id="siparis_SubeKodu" class="form-control-custom" value="0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Özel Kod</label>
                        <input id="siparis_OzelKod" class="form-control-custom" value="1" readonly />
                    </div>
                </div>

                <div class="section-title" style="margin-top:12px;">KALEMLER</div>
                <table class="table-custom" id="siparis_KalemTable" style="font-size:11px; margin-bottom:8px;">
                    <thead>
                        <tr>
                            <th>Stok Kodu *</th>
                            <th>Depo</th>
                            <th>Miktar *</th>
                            <th>Fiyat</th>
                            <th style="width:30px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><input class="form-control-custom siparis_stokKodu" placeholder="Stok" style="font-size:11px; padding:4px;" /></td>
                            <td><input class="form-control-custom siparis_depoKodu" value="10" style="font-size:11px; padding:4px;" /></td>
                            <td><input class="form-control-custom siparis_miktar" value="1" style="font-size:11px; padding:4px;" /></td>
                            <td><input class="form-control-custom siparis_bf" value="0" style="font-size:11px; padding:4px;" /></td>
                            <td class="text-center">
                                <button type="button" class="btn-custom btn-danger-custom siparis_btnRemoveLine" style="padding:2px 6px; font-size:11px;">X</button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <button type="button" class="btn-custom btn-primary-custom" id="siparis_btnAddLine" style="width:100%; margin-bottom:8px; padding:6px; font-size:12px;">
                    + Kalem Ekle
                </button>

                <button onclick="createCustomerOrder()" class="btn-custom btn-success-custom" style="width:100%; margin-top:8px;">
                    ✓ Sipariş Oluştur
                </button>
            </div>

            <div class="section-divider"></div>

            <div class="section-title">MEVCUT SİPARİŞLER</div>
            <div id="customerOrdersContainer">
                <div class="loading">Yükleniyor...</div>
            </div>

        </div>
    </div>

    <!-- ========================================
         2️⃣  İŞ EMRİ
    ========================================= -->
    <div class="workflow-panel">
        <div class="panel-header">
            <span>🔧 İş Emri</span>
            <span class="step-indicator">2</span>
        </div>
        <div class="panel-body">

            <div class="create-form">
                <div class="form-group">
                    <label class="form-label">İş Emri No</label>
                    <input id="isemri_IsEmriNo" class="form-control-custom" placeholder="000000000000010" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Tarih</label>
                        <input id="isemri_Tarih" type="date" class="form-control-custom" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stok Kodu</label>
                        <input id="isemri_StokKodu" class="form-control-custom" placeholder="DK1016" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Miktar</label>
                        <input id="isemri_Miktar" type="number" step="0.01" class="form-control-custom" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Teslim Tarihi</label>
                        <input id="isemri_TeslimTarihi" type="date" class="form-control-custom" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Depo Kodu</label>
                        <input id="isemri_DepoKodu" type="number" class="form-control-custom" value="4000" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Çıkış Depo</label>
                        <input id="isemri_CikisDepoKodu" type="number" class="form-control-custom" value="4000" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Sipariş No (Opsiyonel)</label>
                    <input id="isemri_SiparisNo" class="form-control-custom" placeholder="Boş bırakılabilir" />
                </div>

                <button onclick="createProductionOrder()" class="btn-custom btn-primary-custom" style="width:100%; margin-top:8px;">
                    ✓ İş Emri Oluştur
                </button>
            </div>

            <div class="section-divider"></div>

            <div class="section-title">MEVCUT İŞ EMİRLERİ</div>
            <div id="productionOrdersContainer">
                <div class="loading">Yükleniyor...</div>
            </div>

        </div>
    </div>

    <!-- ========================================
         3️⃣  ÜRETİM SONU KAYDI
    ========================================= -->
    <div class="workflow-panel">
        <div class="panel-header">
            <span>🏭 Üretim Sonu Kaydı</span>
            <span class="step-indicator">3</span>
        </div>
        <div class="panel-body">

            <div id="productionReceiptContent">
                <div class="empty-state">
                    <div class="empty-state-icon">📦</div>
                    <div>Sol panelden bir iş emri seçin</div>
                    <div style="font-size: 12px; color: var(--text-secondary); margin-top: 8px;">
                        Seçilen iş emri için üretim kaydı oluşturulacak
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ========================================
         4️⃣  ÜRETİM FİŞLERİ
    ========================================= -->
    <div class="workflow-panel">
        <div class="panel-header">
            <span>📊 Üretim Fişleri</span>
            <span class="step-indicator">4</span>
        </div>
        <div class="panel-body">

            <div id="finishedGoodsContainer">
                <div class="loading">Yükleniyor...</div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        let selectedCustomerOrderNo = null;
        let selectedProductionOrderNo = null;

        // ========================================
        //  SAYFA YÜKLENDİĞİNDE
        // ========================================
        document.addEventListener("DOMContentLoaded", async function () {
            console.log("🚀 Sayfa yüklendi - FullProductionWorkflow");

            // Bugünün tarihini otomatik doldur
            let today = new Date().toISOString().split('T')[0];
            document.getElementById("siparis_Tarih").value = today;
            document.getElementById("siparis_TesTarih").value = today;
            document.getElementById("isemri_Tarih").value = today;
            document.getElementById("isemri_TeslimTarihi").value = today;

            console.log("📅 Tarihler otomatik dolduruldu:", today);

            // Kalem tablosu event handler'ları
            attachSiparisKalemHandlers();

            await loadCustomerOrders();
            await loadProductionOrders();
            await loadFinishedGoods();
        });

        // ========================================
        //  SİPARİŞ KALEM SATIRLARI YÖNETİMİ
        // ========================================
        document.getElementById("siparis_btnAddLine").addEventListener("click", function () {
            console.log("➕ Yeni kalem satırı ekleniyor");
            let tbody = document.querySelector("#siparis_KalemTable tbody");
            let tr = document.createElement("tr");
            tr.innerHTML = `
                <td><input class="form-control-custom siparis_stokKodu" placeholder="Stok" style="font-size:11px; padding:4px;" /></td>
                <td><input class="form-control-custom siparis_depoKodu" value="10" style="font-size:11px; padding:4px;" /></td>
                <td><input class="form-control-custom siparis_miktar" value="1" style="font-size:11px; padding:4px;" /></td>
                <td><input class="form-control-custom siparis_bf" value="0" style="font-size:11px; padding:4px;" /></td>
                <td class="text-center">
                    <button type="button" class="btn-custom btn-danger-custom siparis_btnRemoveLine" style="padding:2px 6px; font-size:11px;">X</button>
                </td>
            `;
            tbody.appendChild(tr);
            attachSiparisKalemHandlers();
        });

        function attachSiparisKalemHandlers() {
            document.querySelectorAll(".siparis_btnRemoveLine").forEach(btn => {
                btn.onclick = function () {
                    let tbody = document.querySelector("#siparis_KalemTable tbody");
                    if (tbody.querySelectorAll("tr").length > 1) {
                        console.log("🗑️ Kalem satırı siliniyor");
                        let tr = this.closest("tr");
                        tr.parentNode.removeChild(tr);
                    } else {
                        alert("En az bir kalem satırı olmalıdır.");
                        console.warn("⚠️ Son satır silinemez");
                    }
                };
            });
        }

        // ========================================
        //  1️⃣  MÜŞTERİ SİPARİŞLERİNİ YÜK
        // ========================================
        async function loadCustomerOrders() {
            console.log("📋 Müşteri siparişleri yükleniyor...");
            try {
                const response = await fetch('/MusteriSiparisi/List?pageSize=100');
                console.log("📋 Response status:", response.status);

                const html = await response.text();
                console.log("📋 HTML response alındı, parse ediliyor...");

                // HTML'den JSON data çekme (ViewBag'den)
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const table = doc.querySelector('table');

                const container = document.getElementById('customerOrdersContainer');

                if (!table) {
                    console.warn("⚠️ Sipariş tablosu bulunamadı");
                    container.innerHTML = '<div class="empty-state">Sipariş bulunamadı</div>';
                    return;
                }

                const rows = table.querySelectorAll('tbody tr');
                console.log("📋 Toplam sipariş sayısı:", rows.length);

                if (rows.length === 0) {
                    container.innerHTML = '<div class="empty-state">Sipariş bulunamadı</div>';
                    return;
                }

                let html_output = '<div style="display:flex; flex-direction:column; gap:8px;">';

                rows.forEach((row, idx) => {
                    const cells = row.querySelectorAll('td');
                    if (cells.length >= 3) {
                        const fisNo = cells[0].textContent.trim();
                        const cariKod = cells[1].textContent.trim();
                        const tarih = cells[2].textContent.trim();

                        console.log(`📋 Sipariş ${idx + 1}: ${fisNo} - ${cariKod}`);

                        // Sipariş başlığı (tıklanabilir)
                        html_output += `
                            <div style="border:1px solid var(--border-color); border-radius:6px; overflow:hidden;">
                                <div onclick="toggleOrderKalems('${fisNo}')"
                                     style="padding:10px 12px; background:var(--bg-hover); cursor:pointer; display:flex; justify-content:space-between; align-items:center;"
                                     onmouseover="this.style.background='#e6e9ed'"
                                     onmouseout="this.style.background='var(--bg-hover)'">
                                    <div style="display:flex; gap:12px; align-items:center;">
                                        <span id="arrow-${fisNo}" style="font-size:14px;">▶</span>
                                        <strong>${fisNo}</strong>
                                        <span style="color:var(--text-secondary);">${cariKod}</span>
                                        <span style="color:var(--text-secondary); font-size:12px;">${tarih}</span>
                                    </div>
                                    <span id="kalem-count-${fisNo}" style="background:#e3f2fd; color:#0366d6; padding:2px 8px; border-radius:12px; font-size:11px; font-weight:600;">
                                        ...
                                    </span>
                                </div>

                                <div id="kalems-${fisNo}" style="display:none; padding:0;">
                                    <div class="loading" style="padding:20px;">Kalemler yükleniyor...</div>
                                </div>
                            </div>
                        `;
                    }
                });

                html_output += '</div>';
                container.innerHTML = html_output;

                console.log("✅ Müşteri siparişleri yüklendi");

            } catch (err) {
                console.error("❌ loadCustomerOrders ERROR:", err);
                document.getElementById('customerOrdersContainer').innerHTML =
                    '<div class="empty-state">Hata: ' + err.message + '</div>';
            }
        }

        // ========================================
        //  SİPARİŞ KALEMLERİNİ AÇ/KAPA
        // ========================================
        async function toggleOrderKalems(fisNo) {
            console.log("🔄 Sipariş kalemleri toggle:", fisNo);

            const kalemsDiv = document.getElementById(`kalems-${fisNo}`);
            const arrow = document.getElementById(`arrow-${fisNo}`);

            // Kapalıysa aç ve kalemleri yükle
            if (kalemsDiv.style.display === 'none') {
                console.log("📂 Kalemler açılıyor ve yükleniyor...");
                kalemsDiv.style.display = 'block';
                arrow.textContent = '▼';

                // Kalemleri yükle
                await loadOrderKalems(fisNo);
            } else {
                console.log("📁 Kalemler kapatılıyor");
                kalemsDiv.style.display = 'none';
                arrow.textContent = '▶';
            }
        }

        // ========================================
        //  SİPARİŞ KALEMLERİNİ YÜKLE
        // ========================================
        async function loadOrderKalems(fisNo) {
            console.log("📥 Sipariş detayı getiriliyor:", `/MusteriSiparisi/GetFull?fisNo=${fisNo}`);

            const kalemsDiv = document.getElementById(`kalems-${fisNo}`);
            const kalemCountBadge = document.getElementById(`kalem-count-${fisNo}`);

            try {
                const response = await fetch(`/MusteriSiparisi/GetFull?fisNo=${fisNo}`);
                console.log("📥 Response status:", response.status);

                const result = await response.json();
                console.log("📥 API Response:", result);

                if (!result.IsSuccessful) {
                    console.error("❌ Sipariş detayı başarısız:", result.ErrorDesc);
                    kalemsDiv.innerHTML = '<div style="padding:12px; color:var(--danger-red);">Kalemler yüklenemedi</div>';
                    return;
                }

                const data = result.Data;
                console.log("📦 Data:", data);
                console.log("📦 FatUst:", data.FatUst);
                console.log("📦 Kalems:", data.Kalems);

                const kalemler = data.Kalems || [];
                console.log("📦 Kalem sayısı:", kalemler.length);

                // Badge'i güncelle
                kalemCountBadge.textContent = `${kalemler.length} Kalem`;

                if (kalemler.length === 0) {
                    console.warn("⚠️ Siparişte kalem yok");
                    kalemsDiv.innerHTML = '<div style="padding:12px; color:var(--text-secondary); text-align:center;">Kalem bulunamadı</div>';
                    return;
                }

                // Kalemler tablosunu oluştur
                let html = `
                    <table class="table-custom" style="margin:0; font-size:11px;">
                        <thead>
                            <tr style="background:#f0f0f0;">
                                <th style="padding:6px 12px;">Stok Kodu</th>
                                <th style="padding:6px 12px;">Depo</th>
                                <th style="padding:6px 12px;">Miktar</th>
                                <th style="padding:6px 12px;">Fiyat</th>
                                <th style="padding:6px 12px; width:120px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                `;

                kalemler.forEach((kalem, kidx) => {
                    const stokKodu = kalem.StokKodu || kalem.stokKodu || '-';
                    const depoKodu = kalem.DEPO_KODU || kalem.depo_KODU || kalem.DepoKodu || kalem.depoKodu || '-';
                    const miktar = kalem.STra_GCMIK || kalem.stra_GCMIK || kalem.Miktar || kalem.miktar || 0;
                    const fiyat = kalem.STra_BF || kalem.stra_BF || kalem.Fiyat || kalem.fiyat || 0;

                    console.log(`  📦 Kalem ${kidx + 1}: ${stokKodu} | Miktar: ${miktar}`);

