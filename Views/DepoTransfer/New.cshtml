@{
    ViewData["Title"] = "Yeni Depo Transfer Fişi";
}

<h2>Yeni Depo Transfer Fişi (docType = 5)</h2>

<div class="card">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label">Seri</label>
                <input id="seri" class="form-control" placeholder="Örn: D" value="D" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fiş No (FATIRS_NO)</label>
                <input id="fisNo" class="form-control" placeholder="000000000000123" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Tarih (opsiyonel)</label>
                <input id="tarih" class="form-control" placeholder="YYYY-MM-DD HH:MM:SS" />
                <small class="text-muted">Boş bırakırsanız bugünün tarihi kullanılır</small>
            </div>
            <div class="col-md-2">
                <label class="form-label">Şube Kodu</label>
                <input id="subeKodu" class="form-control" value="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Cari Kod (Opsiyonel)</label>
                <input id="cariKod" class="form-control" placeholder="Boş bırakılabilir" />
            </div>
        </div>

        <hr />

        <h5>Kalemler</h5>

        <table class="table table-sm table-bordered" id="kalemTable">
            <thead class="table-light">
                <tr>
                    <th>Stok Kodu *</th>
                    <th>Çıkış Depo (DEPO_KODU) *</th>
                    <th>Giriş Depo (Gir_Depo_Kodu) *</th>
                    <th>Miktar (STra_GCMIK) *</th>
                    <th>Birim Fiyat (STra_BF)</th>
                    <th>Referans Kodu</th>
                    <th style="width:40px;"></th>
                </tr>
            </thead>
            <tbody>
                <!-- Başlangıçta tek satır -->
                <tr>
                    <td><input class="form-control form-control-sm stokKodu" placeholder="Stok kodu" /></td>
                    <td><input class="form-control form-control-sm depoKodu" value="" /></td>
                    <td><input class="form-control form-control-sm girDepoKodu" value="2" /></td>
                    <td><input class="form-control form-control-sm miktar" value="1" /></td>
                    <td><input class="form-control form-control-sm bf" value="0" /></td>
                    <td><input class="form-control form-control-sm referansKodu" value="1" /></td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-danger btnRemoveLine">X</button>
                    </td>
                </tr>
            </tbody>
        </table>

        <button type="button" class="btn btn-sm btn-secondary mb-3" id="btnAddLine">+ Kalem Ekle</button>

        <div class="mt-3">
            <button type="button" class="btn btn-primary" id="btnSave">Fişi Oluştur</button>
            <a href="@Url.Action("List", "DepoTransfer")" class="btn btn-outline-secondary">Listeye Dön</a>
        </div>

        <div id="resultArea" class="mt-3" style="display:none;">
            <h5>API Yanıtı:</h5>
            <pre id="resultJson" style="white-space:pre-wrap; background:#f5f5f5; padding:10px;"></pre>
        </div>
    </div>
</div>



@section Scripts {
    <script>

        // ===================================================
        // SATIR SİLME
        // ===================================================
        function attachRemoveHandlers() {
            document.querySelectorAll(".btnRemoveLine").forEach(btn => {
                btn.onclick = function () {
                    let tbody = document.querySelector("#kalemTable tbody");
                    if (tbody.querySelectorAll("tr").length > 1) {
                        this.closest("tr").remove();
                    } else {
                        alert("En az bir kalem olmalı.");
                    }
                };
            });
        }
        attachRemoveHandlers();


        // ===================================================
        // YENİ SATIR EKLE + FOCUS
        // ===================================================
        function addNewLineAndFocus() {
            let tbody = document.querySelector("#kalemTable tbody");
            let row = document.createElement("tr");

            row.innerHTML = `
                <td><input class="form-control form-control-sm stokKodu" placeholder="Stok / Barkod" /></td>
                <td><input class="form-control form-control-sm depoKodu" value="10" /></td>
                <td><input class="form-control form-control-sm girDepoKodu" value="0" /></td>
                <td><input class="form-control form-control-sm miktar" value="1" /></td>
                <td><input class="form-control form-control-sm bf" value="0" /></td>
                <td><input class="form-control form-control-sm referansKodu" value="1" /></td>
                <td class="text-center"><button type="button" class="btn btn-sm btn-danger btnRemoveLine">X</button></td>
            `;

            tbody.appendChild(row);
            attachRemoveHandlers();

            row.querySelector(".stokKodu").focus();
        }


        // ===================================================
        // ENTER = Barkod okundu + miktar popup
        // ===================================================
        document.addEventListener("keydown", function (e) {
            let active = document.activeElement;

            if (!active.classList.contains("stokKodu")) return;

            if (e.key === "Enter") {
                e.preventDefault();

                let tr = active.closest("tr");
                let miktarInput = tr.querySelector(".miktar");

                let miktar = prompt("Miktar:", "1");
                if (!miktar || miktar.trim() === "") return;

                miktarInput.value = miktar;

                // Yeni satır oluştur ve fokus ata
                addNewLineAndFocus();
            }
        });


        // ===================================================
        // KAYDET (POST)
        // ===================================================
        document.getElementById("btnSave").addEventListener("click", function () {

            let seri = document.getElementById("seri").value.trim();
            let fisNo = document.getElementById("fisNo").value.trim();

            if (!seri) return alert("Seri boş olamaz.");
            if (!fisNo) return alert("Fiş No boş olamaz.");

            let kalems = [];

            document.querySelectorAll("#kalemTable tbody tr").forEach(tr => {
                let stokKodu = tr.querySelector(".stokKodu").value.trim();
                let depo = tr.querySelector(".depoKodu").value.trim();
                let girDepo = tr.querySelector(".girDepoKodu").value.trim();
                let miktar = tr.querySelector(".miktar").value.trim();
                let bf = tr.querySelector(".bf").value.trim();
                let ref = tr.querySelector(".referansKodu").value.trim();

                if (!stokKodu) return;

                kalems.push({
                    StokKodu: stokKodu,
                    DEPO_KODU: depo ? parseInt(depo) : 10,
                    Gir_Depo_Kodu: girDepo ? parseInt(girDepo) : 0,
                    STra_GCMIK: parseFloat(miktar),
                    STra_BF: parseFloat(bf),
                    ReferansKodu: ref || "1"
                });
            });

            if (kalems.length === 0) return alert("Kalem yok!");

            let payload = {
                FaturaTip: 5,
                Seri: seri,
                SonNumaraYazilsin: false,
                FatUst: {
                    FATIRS_NO: fisNo,
                    Tarih: null,
                    Sube_Kodu: 0,
                    KDV_DAHILMI: true,
                    Tip: 5,
                    TIPI: 0,
                    AMBHARTUR: 0
                },
                Kalems: kalems
            };

            fetch('/DepoTransfer/Create', {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            })
            .then(r => r.json())
            .then(res => {
                document.getElementById("resultArea").style.display = "block";
                document.getElementById("resultJson").textContent = JSON.stringify(res, null, 2);

                if (res.IsSuccessful) alert("Fiş oluşturuldu!");
                else alert("HATA: " + (res.ErrorDesc || "Bilinmiyor"));
            })
            .catch(err => alert("Hata: " + err));
        });

    </script>
}
