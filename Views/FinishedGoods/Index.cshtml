@{
    ViewData["Title"] = "Üretim Fişleri";
}

<div class="container mt-4">
    <h2 class="mb-4">🏭 Üretim Fişleri</h2>

    <table id="finishedTable" class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>Fiş No</th>
                <th>Tarih</th>
                <th>Depo</th>
                <th>Malzeme</th>
                <th>Miktar</th>
                <th>Birim</th>
                <th style="width:50px">📌</th>
            </tr>
        </thead>
        <tbody>
            <tr><td colspan="7" class="text-center">Yükleniyor...</td></tr>
        </tbody>
    </table>

    <div class="d-flex justify-content-between mt-3">
        <button id="prevPage" class="btn btn-secondary btn-sm">⬅ Önceki</button>
        <span id="pageInfo" class="fw-bold"></span>
        <button id="nextPage" class="btn btn-secondary btn-sm">İleri ➡</button>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async () => {

            let currentPage = 1;
            const pageSize = 10;

            const tbody = document.querySelector("#finishedTable tbody");
            const pageInfo = document.querySelector("#pageInfo");

            // --- SAYFALI LİSTE ---
            async function loadList(page = 1) {
                tbody.innerHTML =
                    "<tr><td colspan='7' class='text-center'>Yükleniyor...</td></tr>";

                try {
                    const res = await fetch(`/FinishedGoods/GetAll?page=${page}&pageSize=${pageSize}`);
                    const json = await res.json();

                    const data = json.data || [];
                    const total = json.totalCount || data.length;

                    pageInfo.textContent = `Sayfa ${page}`;

                    tbody.innerHTML = "";

                    if (data.length === 0) {
                        tbody.innerHTML =
                            "<tr><td colspan='7' class='text-center text-muted'>Kayıt bulunamadı</td></tr>";
                        return;
                    }

                    data.forEach(x => {
                        tbody.innerHTML += `
                            <tr class="fis-row" data-id="${x.fisNo}">
                                <td>${x.fisNo}</td>
                                <td>${x.tarih}</td>
                                <td>${x.depo}</td>
                                <td>${x.malzeme}</td>
                                <td>${x.miktar}</td>
                                <td>${x.birim}</td>
                                <td class="text-center" style="cursor:pointer">⤵</td>
                            </tr>

                            <tr class="pivot-row d-none" id="pivot-${x.fisNo}">
                                <td colspan="7">
                                    <div class="p-2 text-center text-muted">Yükleniyor...</div>
                                </td>
                            </tr>
                        `;
                    });

                } catch (err) {
                    tbody.innerHTML =
                        "<tr><td colspan='7' class='text-center text-danger'>Hata: " + err.message + "</td></tr>";
                }
            }

            await loadList(currentPage);

            // Sayfa değiştirme
            document.getElementById("prevPage").addEventListener("click", async () => {
                if (currentPage > 1) {
                    currentPage--;
                    await loadList(currentPage);
                }
            });

            document.getElementById("nextPage").addEventListener("click", async () => {
                currentPage++;
                await loadList(currentPage);
            });


            // --- SATIRA TIKLAYINCA PIVOT DETAYI AÇ/KAPA ---
            document.addEventListener("click", async e => {
                const tr = e.target.closest(".fis-row");
                if (!tr) return;

                const fisNo = tr.dataset.id;
                const pivot = document.getElementById(`pivot-${fisNo}`);
                const pivotTd = pivot.querySelector("td");

                // açık ise kapat
                if (!pivot.classList.contains("d-none")) {
                    pivot.classList.add("d-none");
                    return;
                }

                // önce kapalıysa aç
                pivot.classList.remove("d-none");
                pivotTd.innerHTML = "<div class='p-2 text-muted'>Yükleniyor...</div>";

                // detay getir
                try {
                    const res = await fetch(`/FinishedGoods/Detail/${fisNo}`);
                    const json = await res.json();

                    if (!json.success) {
                        pivotTd.innerHTML =
                            `<div class='text-danger p-2'>${json.message}</div>`;
                        return;
                    }

                    const data = json.data;
                    const kalemler = data.kalem || [];

                    if (kalemler.length === 0) {
                        pivotTd.innerHTML =
                            "<div class='p-2 text-muted text-center'>Kalem bulunamadı</div>";
                        return;
                    }

                    let html = `
                        <div class="fw-bold mb-2">
                            <strong>Fiş No:</strong> ${data.uretSon_FisNo} |
                            <strong>Tarih:</strong> ${data.uretSon_Tarih} |
                            <strong>Mamul:</strong> ${data.uretSon_Mamul} |
                            <strong>Miktar:</strong> ${data.uretSon_Miktar} |
                            <strong>Depo:</strong> ${data.uretSon_Depo}
                        </div>

                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-warning">
                                <tr>
                                    <th>#</th>
                                    <th>Stok Kodu</th>
                                    <th>Depo</th>
                                    <th>Miktar</th>
                                    <th>BG Tip</th>
                                    <th>Seri</th>
                                </tr>
                            </thead>
                            <tbody>
                    `;

                    kalemler.forEach(k => {
                        html += `
                            <tr class="kalem-row" data-fis="${fisNo}">
                                <td>${k.index}</td>
                                <td>${k.stokKodu}</td>
                                <td>${k.depoKodu}</td>
                                <td class="editable-qty" contenteditable="true">${k.miktar}</td>
                                <td>${k.bGTIP}</td>
                                <td>${k.seriVarMi ? "✅" : "❌"}</td>
                            </tr>
                        `;
                    });

                    html += "</tbody></table>";

                    pivotTd.innerHTML = html;

                } catch (err) {
                    pivotTd.innerHTML =
                        "<div class='p-2 text-danger text-center'>Hata oluştu</div>";
                }
            });


            // --- INLINE MİKTAR DÜZENLEME ---
            document.addEventListener("blur", async e => {
                const td = e.target.closest(".editable-qty");
                if (!td) return;

                const tr = td.closest(".kalem-row");

                const newValue = parseFloat(td.textContent) || 0;
                td.textContent = newValue.toFixed(3);

                const fis = tr.dataset.fis;
                const cells = tr.querySelectorAll("td");

                const dto = {
                    fisNo: fis,
                    index: parseInt(cells[0].textContent.trim()),
                    stokKodu: cells[1].textContent.trim(),
                    depoKodu: parseInt(cells[2].textContent.trim()),
                    miktar: newValue,
                    bGTIP: cells[4].textContent.trim(),
                    seriVarMi: cells[5].textContent.includes("✅"),
                    aciklama: ""
                };

                try {
                    const res = await fetch("/FinishedGoods/UpdateQuantity", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(dto)
                    });

                    const json = await res.json();

                    td.style.backgroundColor = json.success ? "#d4edda" : "#f8d7da";
                    setTimeout(() => td.style.backgroundColor = "", 1500);

                } catch {
                    td.style.backgroundColor = "#f8d7da";
                    setTimeout(() => td.style.backgroundColor = "", 1500);
                }

            }, true);

        });
    </script>
}
